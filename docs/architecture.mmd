flowchart LR
  user["App owner / security reviewer"]
  appsec["kelp-claw appsec audit"]
  dockerfile["Dockerfile target"]
  docker["Docker build metadata\nstdout, stderr, image id"]
  scanner["Passive scanner imports\nSARIF, Nuclei, ZAP, Nmap, Burp, Nessus"]
  evidence["Evidence workspace\nnormalized findings + source refs"]
  policy["Policy pack\nappsec-agent-baseline"]
  agent["Triage assistant\n--agent-command"]
  triage["AppSec triage JSON\nsummary, findings, next steps, limitations"]
  sarif["SARIF output"]
  bundle["Signed audit bundle\nmanifest, signature, attestation"]
  reviewer["Static reviewer handoff\nindex.html + logs"]

  user --> appsec
  dockerfile --> appsec
  appsec --> docker
  scanner --> evidence
  appsec --> evidence
  policy --> appsec
  evidence --> agent
  docker --> agent
  policy --> agent
  agent --> triage
  evidence --> sarif
  triage --> sarif
  docker --> bundle
  evidence --> bundle
  triage --> bundle
  sarif --> bundle
  bundle --> reviewer

  subgraph safety["Default safety boundary"]
    policy
  end

  subgraph artifacts["Reproducible evidence"]
    docker
