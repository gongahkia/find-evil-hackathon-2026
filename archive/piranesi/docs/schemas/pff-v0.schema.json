{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://piranesi.local/schemas/pff-v0.schema.json",
  "title": "Piranesi Finding Format v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "producer", "findings"],
  "properties": {
    "schema_version": {
      "const": "piranesi.pff.v0"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "engagement": {
      "type": "object"
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "known_gaps": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "severity",
        "confidence",
        "status",
        "assets",
        "evidence",
        "source_references",
        "provenance"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "severity": {
          "enum": ["info", "low", "medium", "high", "critical"]
        },
        "confidence": {
          "enum": ["info", "tool-observed", "low", "medium", "high", "confirmed"]
        },
        "status": {
          "enum": ["new", "open", "closed", "changed", "regressed", "accepted-risk"]
        },
        "description": { "type": ["string", "null"] },
        "remediation": { "type": ["string", "null"] },
        "assets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "service": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "port": { "type": ["integer", "null"] },
            "protocol": { "type": ["string", "null"] },
            "name": { "type": ["string", "null"] },
            "product": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] }
          }
        },
        "affected_instances": {
          "type": "array",
          "items": { "$ref": "#/$defs/affected_instance" },
          "default": []
        },
        "weakness_ids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "references": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "source_references": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_reference" }
        },
        "provenance": {
          "type": "object"
        },
        "chain_of_custody": {
          "type": ["object", "null"]
        },
        "retest_status": {
          "type": ["string", "null"],
          "enum": ["new", "open", "closed", "changed", "regressed", "ambiguous", null]
        }
      }
    },
    "affected_instance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset"],
      "properties": {
        "asset": { "type": "string" },
        "service": { "$ref": "#/$defs/service_or_null" },
        "location": { "type": ["string", "null"] },
        "metadata": { "type": "object" }
      }
    },
    "service_or_null": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "port": { "type": ["integer", "null"] },
        "protocol": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "product": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value", "redacted"],
      "properties": {
        "kind": { "type": "string" },
        "value": { "type": "string" },
        "redacted": { "type": "boolean" },
        "locator": { "type": ["string", "null"] }
      }
    },
    "source_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "input_sha256", "raw_path"],
      "properties": {
        "tool": { "type": "string" },
        "input_sha256": { "type": "string" },
        "raw_path": { "type": "string" },
        "locator": { "type": ["string", "null"] },
        "metadata": { "type": "object" }
      }
    }
  }
}
